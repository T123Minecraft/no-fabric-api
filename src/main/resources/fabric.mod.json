{
	"schemaVersion": 1,
	"id": "nofabricapi",
	"version": "${version}",
	"name": "No Fabric API",
	"description": "This is a mod. When you install this mod with fabric api, the game will crash.",
	"authors": [
		"T123Minecraft"
	],
	"contact": {
		"sources": "https://github.com/T123Minecraft/no-fabric-api",
		"issues": "https://github.com/T123Minecraft/no-fabric-api/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/nofabricapi/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.t123minecraft.nofabricapi.NoFabricAPI"
		],
		"client": [
			"com.t123minecraft.nofabricapi.client.NoFabricAPIClient"
		]
	},
	"mixins": [
		"nofabricapi.mixins.json",
		{
			"config": "nofabricapi.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": "*",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}